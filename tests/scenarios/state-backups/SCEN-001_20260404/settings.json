{
  "cleanupPeriodDays": 90,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "1800000",
    "BASH_MAX_TIMEOUT_MS": "1800000",
    "MCP_TIMEOUT": "1800000",
    "MCP_TOOL_TIMEOUT": "1800000",
    "ENABLE_BACKGROUND_TASKS": "1",
    "FORCE_AUTO_BACKGROUND_TASKS": "0",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "MAX_MCP_OUTPUT_TOKENS": "35000",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "ENABLE_TOOL_SEARCH": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "90",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./.keys)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/on-file-write.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git_safety_guard.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/dist/tldr-read-enforcer.mjs",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/dist/tldr-context-inject.mjs",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/dist/arch-context-inject.mjs",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/dist/session-start-tldr-cache.mjs",
            "timeout": 2
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3333/api/session-stop",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3333/api/session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/emanuelesabetta/ai-maestro/scripts/claude-hooks/ai-maestro-hook.cjs",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/emanuelesabetta/.claude/statusline.sh"
  },
